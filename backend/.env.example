# ──────────────────────────────────────────────────────
# Read in Peace — Backend Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#    cp .env.example .env
#
# Variables marked [REQUIRED] must be set for the app to start.
# Variables with defaults are optional and can be omitted.
# ──────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string.
# Format: postgres://user:password@host:5432/database
DATABASE_URL=postgres://readinpeace:readinpeace@localhost:5432/readinpeace

# ── Stripe ────────────────────────────────────────────
# [REQUIRED] Stripe secret key.
# Use a restricted API key (rk_test_... or rk_live_...) for better security:
#   https://docs.stripe.com/keys/restricted-api-keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here

# [REQUIRED] Stripe webhook signing secret (whsec_...).
# Get one from the Stripe Dashboard → Developers → Webhooks
# For local testing, run `stripe listen --forward-to localhost:4000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ── Auth (Better Auth) ────────────────────────────────
# Base URL for auth redirects. Must match the frontend origin.
# Defaults to 'http://localhost:3000' if omitted.
BETTER_AUTH_URL=http://localhost:3000

# Secret for session encryption. Minimum 16 characters.
# Generate with: openssl rand -hex 32
# Falls back to a dev default if omitted (insecure — set in production).
AUTH_SECRET=change-me-to-a-random-string-at-least-16-chars

# ── Server ────────────────────────────────────────────
# Port to listen on. Default: 4000
PORT=4000

# Node environment. Default: development
# Allowed: development, production, test
NODE_ENV=development

# Log level for pino. Default: info
# Allowed: fatal, error, warn, info, debug, trace, silent
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins.
# Defaults to 'http://localhost:3000' if omitted.
CORS_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────
# URL used for Stripe redirect URLs (success_url, cancel_url).
# Defaults to BETTER_AUTH_URL, then 'http://localhost:3000'.
FRONTEND_URL=http://localhost:3000
